{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|gif|webp|ico|svg|js|css|map)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/share/memory/:path*",
      "destination": "https://api.foxtales.cc/share/memory/:path*",
      "headers": {
        "X-API-Key": "${VERCEL_API_KEY}"
      }
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.foxtales.cc/api/:path*",
      "headers": {
        "X-API-Key": "${VERCEL_API_KEY}"
      }
    },
    {
      "source": "/psychhub/:path*",
      "destination": "https://api.foxtales.cc/psychhub/:path*",
      "headers": {
        "X-API-Key": "${VERCEL_API_KEY}"
      }
    },
    {
      "source": "/((?!share/memory|api|psychhub|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
